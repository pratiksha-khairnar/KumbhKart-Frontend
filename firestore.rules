// 📁 firestore.rules
// Firebase Console mein jaake Firestore > Rules mein paste karo

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ✅ Products — sabko read karne do, sirf admin write kar sakta hai
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null; // Sirf logged-in users (admin) write kar sakte hain
    }
  }
}

